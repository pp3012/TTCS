
# TTCS WEB – Server Environment Variables (Mẫu)
# ================================================
# QUAN TRỌNG:
#   1. Sao chép file này và đổi tên thành .env (không có .example)
#   2. Điền các giá trị thực tế vào bên dưới
#   3. KHÔNG BAO GIỜ commit file .env lên GitHub
# ================================================

# ---------- Database (MySQL) ----------
DB_HOST=127.0.0.1          # Thường là localhost hoặc 127.0.0.1
DB_PORT=3306               # Cổng MySQL mặc định (không cần thay đổi)
DB_USER=root               # Username MySQL của bạn (thường là root)
DB_PASSWORD=your_password  # Mật khẩu MySQL bạn đặt khi cài đặt
DB_NAME=(vd:my_web)             # Tên database đã tạo

# ---------- JWT (Xác thực người dùng) ----------
JWT_SECRET=your_jwt_secret_key_here   # Chuỗi bí mật bất kỳ, dùng để mã hóa token (có thể gõ ngẫu nhiên)
JWT_EXPIRES_IN=7d                      # Thời gian hết hạn token (7d = 7 ngày)

# ---------- Server ----------
PORT=5001          # Cổng server backend sẽ chạy
NODE_ENV=development
